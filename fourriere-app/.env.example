# ================================================================
# PRODUCTION — variables d'environnement Linguema Fourrière
# Copier vers .env sur le serveur Hetzner et remplir avec des valeurs
# fortes. Ne JAMAIS committer .env dans Git.
# ================================================================

# Domaines (sans https://)
API_HOSTNAME=api.fourriere.sn
KEYCLOAK_HOSTNAME=auth.fourriere.sn
FRONTEND_URL=https://www.fourriere.sn

# ACME / Let's Encrypt
ACME_EMAIL=ops@fourriere.sn

# PostgreSQL (mots de passe FORTS, générer avec `openssl rand -base64 32`)
POSTGRES_DB=fourriere_db
POSTGRES_USER=fourriere_prod
POSTGRES_PASSWORD=CHANGE_ME_STRONG_RANDOM_PASSWORD

# Keycloak admin (compte maître du serveur Keycloak)
KEYCLOAK_ADMIN=kc_admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_STRONG_RANDOM_PASSWORD

# Keycloak Admin API (provisioning des users par le backend).
# Le client 'fourriere-admin-sync' est défini dans fourriere-realm.json.
# Son secret est à régénérer dans la console admin Keycloak (Clients →
# fourriere-admin-sync → Credentials → Regenerate) puis reporter ici.
# KEYCLOAK_ADMIN_URL pointe vers le conteneur keycloak (interne au réseau Docker).
KEYCLOAK_ADMIN_URL=http://keycloak:8080
KEYCLOAK_ADMIN_REALM=fourriere
KEYCLOAK_ADMIN_CLIENT_ID=fourriere-admin-sync
KEYCLOAK_ADMIN_CLIENT_SECRET=CHANGE_ME_REGENERATE_IN_KEYCLOAK_CONSOLE

# IPs/CIDR autorisés à accéder à la console admin Keycloak (/admin/*)
# Séparateur : espace. Ex. "1.2.3.4 41.82.0.0/16". Laisser "0.0.0.0/32" pour bloquer.
ADMIN_TRUSTED_IPS=0.0.0.0/32

# Cloudinary (uploads photos)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Rate limit : IPs des proxies de confiance (séparateur virgule).
# Inclure l'IP du container Caddy (généralement la gateway du réseau Docker,
# ex. 172.18.0.1). Pour connaître l'IP après démarrage :
#   docker inspect fourriere-caddy | grep IPAddress
# Si vide, le header X-Forwarded-For n'est pas pris en compte et c'est
# l'IP directe (le container Caddy) qui sera utilisée pour le rate limit.
RATE_LIMIT_TRUSTED_PROXIES=172.18.0.0/16

# (Optionnel) Ajustement des limites
RATE_LIMIT_AUTH=5
RATE_LIMIT_SEARCH=30
RATE_LIMIT_DETAIL=30
