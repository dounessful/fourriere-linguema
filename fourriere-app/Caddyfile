# =====================================================================
# Caddy reverse proxy — Linguema Fourrière (production)
# - Terminaison TLS automatique via Let's Encrypt (ACME_EMAIL)
# - Proxy vers backend et keycloak internes
# - Headers de sécurité ajoutés
# - Admin console Keycloak (/admin/*) bloquée depuis Internet
# =====================================================================

{
    email {$ACME_EMAIL}
    log {
        output stdout
        format console
    }
}

# ----- Backend API -----------------------------------------------------
{$API_HOSTNAME} {
    encode gzip zstd

    header {
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
        X-Content-Type-Options    "nosniff"
        X-Frame-Options           "DENY"
        Referrer-Policy           "strict-origin-when-cross-origin"
        Permissions-Policy        "geolocation=(), camera=(), microphone=()"
        -Server
    }

    reverse_proxy backend:8080
}

# ----- Keycloak --------------------------------------------------------
{$KEYCLOAK_HOSTNAME} {
    encode gzip zstd

    header {
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
        X-Content-Type-Options    "nosniff"
        Referrer-Policy           "strict-origin-when-cross-origin"
        -Server
    }

    # Console admin : accès restreint aux IP de confiance (ADMIN_TRUSTED_IPS)
    # Exemple .env : ADMIN_TRUSTED_IPS="154.125.133.177 41.82.0.0/16"
    @kcAdmin path /admin*
    handle @kcAdmin {
        @adminTrusted remote_ip {$ADMIN_TRUSTED_IPS}
        handle @adminTrusted {
            reverse_proxy keycloak:8080 {
                header_up Host {host}
            }
        }
        handle {
            respond "Administration interface not available publicly" 403
        }
    }

    # Endpoints publics nécessaires au client frontend
    @kcAllowed {
        path /realms/fourriere/*
        path /resources/*
        path /js/*
    }
    handle @kcAllowed {
        reverse_proxy keycloak:8080 {
            header_up Host {host}
        }
    }

    # Tout le reste : 404 (empêche /realms/master, /realms/master/..., etc.)
    handle {
        respond 404
    }
}
